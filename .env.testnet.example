# Hyperliquid Testnet Configuration
# Copy this file to .env and fill in your values

# Network: use 'testnet' for testnet, 'mainnet' for mainnet
HL_NETWORK=testnet

# Testnet API endpoints (Hyperliquid testnet)
HL_API_URL=https://api.hyperliquid-testnet.xyz
HL_WS_URL=wss://ws.hyperliquid-testnet.xyz

# Wallet private key (without 0x prefix for some implementations)
# Generate a new wallet or use an existing Ethereum private key
# WARNING: Use a separate wallet for testnet - never use mainnet wallet keys
WALLET_PRIVATE_KEY=your_private_key_here_without_0x_prefix

# Optional: Vault secret path (for production use with HSM)
# VAULT_SECRET_PATH=/path/to/vault/secret

# Agent configuration
DATA_AGENT_INTERVAL_MS=5000
ANALYSIS_INTERVAL_MS=30000
RISK_CHECK_ENABLED=true

# Database (optional for testnet)
# PG_HOST=localhost
# PG_PORT=5432
# PG_DATABASE=hyperliquid_testnet
# PG_USER=postgres
# PG_PASSWORD=your_password

# Redis (optional for testnet)
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Logging
LOG_LEVEL=debug

# Dashboard Authentication (optional)
# DASHBOARD_USER=admin
# DASHBOARD_PASS=your_secure_password
# Set DASHBOARD_AUTH=false to disable authentication
