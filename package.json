{
  "name": "hyperliquid-trading",
  "version": "1.0.0",
  "description": "Agentic quant trading system for Hyperliquid",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dashboard": "ts-node src/dashboard-server.ts",
    "dashboard:build": "tsc && npm run dashboard",
    "test": "jest",
    "report": "ts-node src/report-cli.ts",
    "report:board": "ts-node src/report-cli.ts summary",
    "report:perf": "ts-node src/report-cli.ts perf",
    "report:trades": "ts-node src/report-cli.ts trades"
  },
  "dependencies": {
    "@nktkas/hyperliquid": "^0.32.1",
    "axios": "^1.6.2",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "express-basic-auth": "^1.2.1",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "winston": "^3.11.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.10",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  }
}
